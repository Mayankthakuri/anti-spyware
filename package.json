{
  "name": "antispyware-realtime-server",
  "version": "2.0.0",
  "description": "Real-time WebSocket server for AntiSpyware Pro",
  "main": "realtime-server.js",
  "scripts": {
    "start": "node realtime-server.js",
    "dev": "nodemon realtime-server.js",
    "server": "./start-server.sh",
    "web": "cd web-app && npm start",
    "mobile": "cd mobile-app && expo start",
    "install-all": "npm install && cd web-app && npm install && cd ../mobile-app && npm install",
    "build-cpp": "make clean && make all"
  },
  "dependencies": {
    "ws": "^8.14.2",
    "chokidar": "^3.5.3"
  },
  "devDependencies": {
    "nodemon": "^3.0.1"
  },
  "engines": {
    "node": ">=16.0.0"
  }
}