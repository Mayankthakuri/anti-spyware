{
  "expo": {
    "name": "AntiSpyware Pro Mobile",
    "slug": "antispyware-pro-mobile",
    "version": "1.0.0",
    "orientation": "portrait",
    "userInterfaceStyle": "dark",
    "splash": {
      "resizeMode": "contain",
      "backgroundColor": "#1f2937"
    },
    "assetBundlePatterns": [
      "**/*"
    ],
    "ios": {
      "supportsTablet": true,
      "bundleIdentifier": "com.antispyware.pro.mobile"
    },
    "android": {
      "adaptiveIcon": {
        "backgroundColor": "#1f2937"
      },
      "package": "com.antispyware.pro.mobile"
    },
    "web": {
      "bundler": "metro"
    }
  }
}